{
  "schemaVersion": 1,
  "id": "worldmirror",
  "version": "${version}",
  "name": "World Mirror",
  "description": "A client-side mod that lets you download the world you are currently playing on a multiplayer server. Captures chunks, entities, and container contents, then exports them as a loadable singleplayer save.",
  "authors": [
    "billstark001"
  ],
  "contact": {
    "sources": "https://github.com/billstark001/world-mirror",
    "issues": "https://github.com/billstark001/world-mirror/issues"
  },
  "license": "MIT",
  "icon": "assets/worldmirror/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "net.billstark001.worldmirror.WorldMirrorClient"
    ],
    "modmenu": [
      "net.billstark001.worldmirror.config.ModMenuApiImpl"
    ]
  },
  "mixins": [
    {
      "config": "worldmirror.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.1.2",
    "java": ">=25",
    "fabric-api": "*",
    "libgui": "*",
    "cloth-config2": ">=26.1.154"
  },
  "suggests": {
    "modmenu": "*"
  }
}